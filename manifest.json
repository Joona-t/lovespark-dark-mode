{
  "manifest_version": 3,
  "name": "LoveSpark Dark Mode",
  "version": "2.0.0",
  "description": "Three beautiful themes for every website — dark mode, bubblegum pink, and hot pink",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["filters/*.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "settings.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "lovespark-dark-mode@lovespark.suite",
      "strict_min_version": "109.0"
    }
  }
}
